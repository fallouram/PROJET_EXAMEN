<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modifier la tâche</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<nav class="navbar-projet">
    <span class="titre">✏️ Modifier une Tâche</span>
    <a href="/">← Retour</a>
</nav>

<div class="container mt-4">
    <div class="card col-md-6 offset-3">
        <div class="card-header bg-warning text-center fw-bold">
            Modification — <%= tache.titre %>
        </div>
        <div class="card-body">
            <form action="/modifier/<%= tache.id %>" method="POST">

                <div class="form-group">
                    <label>Titre</label>
                  
                    <input type="text" class="form-control" name="titre" value="<%= tache.titre %>">
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea name="description" cols="10" rows="5" class="form-control"><%= tache.description %></textarea>
                </div>

                <div class="form-group">
                    <label>Responsable</label>
                    <input type="text" class="form-control" name="responsable" value="<%= tache.responsable || '' %>">
                </div>

                <div class="form-group">
                    <label>Priorité</label>
                    <select class="form-control" name="priorite">
                       
                        <option value="basse"   <%= tache.priorite === 'basse'   ? 'selected' : '' %>>Basse</option>
                        <option value="moyenne" <%= tache.priorite === 'moyenne' ? 'selected' : '' %>>Moyenne</option>
                        <option value="haute"   <%= tache.priorite === 'haute'   ? 'selected' : '' %>>Haute</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Date limite</label>
                    <input type="date" class="form-control" name="date_limite"
                           value="<%= tache.date_limite ? new Date(tache.date_limite).toISOString().slice(0,10) : '' %>">
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-warning btn-sm w-100" type="submit">Sauvegarder</button>
                    <a href="/" class="btn btn-outline-secondary btn-sm w-100">Annuler</a>
                </div>

            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
